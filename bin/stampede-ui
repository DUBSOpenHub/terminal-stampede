#!/usr/bin/env bash
# stampede-ui — Launch Terminal Stampede dashboard or native macOS app
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
UI_DIR="$(cd "$SCRIPT_DIR/../ui" && pwd)"

usage() { cat <<HELP
⚡ Terminal Stampede UI

Usage: stampede-ui [MODE] [OPTIONS]

Modes:
  terminal    Terminal dashboard (default)
  app         Build and launch native macOS app
  build       Build the macOS app only

Options:
  --demo      Simulated agent data
  --dir PATH  Stampede working directory
HELP
}

case "${1:-terminal}" in
  terminal|-t|--demo)
    exec "$UI_DIR/terminal/dashboard.sh" "$@"
    ;;
  app|-a)
    shift
    cd "$UI_DIR/macos"
    swift build 2>&1
    exec "$(swift build --show-bin-path)/StampedeUI" "$@"
    ;;
  build|-b)
    shift
    cd "$UI_DIR/macos"
    swift build "${@:---configuration release}"
    ;;
  --help|-h)
    usage
    ;;
  *)
    echo "Unknown: $1"
    usage
    exit 1
    ;;
esac
